<?xml version="1.0" encoding="UTF-8"?>
<style xmlns="http://purl.org" class="note" version="1.0" demote-non-dropping-particle="sort-only" default-locale="en-GB">
  <info>
    <title>Minimal footnote et al style</title>
    <id>http://www.zotero.org</id>
    <link href="http://www.zotero.org" rel="self"/>
    <author>
      <name>Custom User</name>
    </author>
    <category citation-format="note"/>
    <updated>2024-05-20T12:00:00+00:00</updated>
    <rights license="http://creativecommons.org">This work is licensed under a Creative Commons Attribution-ShareAlike 3.0 License</rights>
  </info>
  <macro name="author-short">
    <names variable="author">
      <name form="short" and="symbol" delimiter-precedes-last="never" />
      <et-al font-style="italic"/>
    </names>
  </macro>
  <!-- FORCE ET-AL HERE FOR FOOTNOTES -->
  <citation et-al-min="2" et-al-use-first="1">
    <layout delimiter="; " suffix=".">
      <group delimiter=", ">
        <text macro="author-short"/>
        <text variable="title" font-style="italic"/>
      </group>
    </layout>
  </citation>
  <!-- FORCE ET-AL HERE FOR BIBLIOGRAPHY -->
  <bibliography et-al-min="2" et-al-use-first="1">
    <layout>
      <group delimiter=" ">
        <text macro="author-short" suffix="."/>
        <text variable="title" font-style="italic" suffix="."/>
        <text variable="container-title" font-style="italic" form="short"/>
        <date variable="issued" prefix="(" suffix=")">
          <date-part name="year"/>
        </date>
      </group>
    </layout>
  </bibliography>
</style>
